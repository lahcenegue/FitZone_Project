# ─── Email ────────────────────────────────────────────────────────────────────
#
# Development: use console backend — emails print to Docker logs, no SMTP needed.
# To see emails: docker logs fitzone_backend
#
# Production: switch to smtp backend and fill in real SMTP credentials.
#
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=FitZone <noreply@fitzone.sa>
SUPPORT_EMAIL=support@fitzone.sa

# ─── Media ───────────────────────────────────────────────────────────────────
MEDIA_URL=/media/
MEDIA_ROOT=/app/media

# ─── Security ────────────────────────────────────────────────────────────────
